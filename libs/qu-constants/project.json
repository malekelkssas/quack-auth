{
  "name": "qu-constants",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/qu-constants/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/qu-constants",
        "main": "libs/qu-constants/src/index.ts",
        "tsConfig": "libs/qu-constants/tsconfig.lib.json",
        "assets": ["libs/qu-constants/*.md"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/qu-constants/tsconfig.lib.json"
      }
    }
  }
}
