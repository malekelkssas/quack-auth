# MongoDB (Docker: docker compose up -d mongodb)
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=mongo
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/quack-auth?authSource=admin
E2E_MONGODB_URI=mongodb://mongo:mongo@localhost:27017/quack-auth-e2e?authSource=admin
MONGODB_DATABASE=quack-auth

# Node Environment
NODE_ENV=development
VITE_NODE_ENV=development
VITE_API_URL=http://localhost:3000/api

# BE CORS — must list the FE origin (pnpm nx serve FE → :4200)
CORS_ORIGIN=http://localhost:4200

# Vite dev server (FE: pnpm nx serve FE → :4200)
# Comma-separated hostnames for server.allowedHosts (e.g. localhost or tunnel hostnames).
VITE_ALLOWED_HOSTS=localhost
# Bind address — use localhost locally, or 0.0.0.0 to listen on all interfaces
VITE_HOST=localhost

# Redux persist — dev obfuscation only (VITE_* is bundled into client JS).
# For real protection, set a runtime key from the user's session (see store/persist-secret.ts).
VITE_REDUX_PERSIST_SECRET_KEY=supersecretkey
