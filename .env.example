# MongoDB (Docker: docker compose up -d mongodb)
MONGO_INITDB_ROOT_USERNAME=mongo
MONGO_INITDB_ROOT_PASSWORD=mongo
MONGODB_URI=mongodb://mongo:mongo@localhost:27017/quack-auth?authSource=admin
E2E_MONGODB_URI=mongodb://mongo:mongo@localhost:27017/quack-auth-e2e?authSource=admin
MONGODB_DATABASE=quack-auth

# Node Environment
NODE_ENV=development
VITE_NODE_ENV=development

# Frontend app origin for CORS credentials
FRONTEND_ORIGIN=http://localhost:4200

# JWT / cookie auth
AUTH_ACCESS_TOKEN_SECRET=change-me-access-secret
AUTH_REFRESH_TOKEN_SECRET=change-me-refresh-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=600
AUTH_REFRESH_TOKEN_TTL_SECONDS=86400
AUTH_ACCESS_COOKIE_NAME=qa_access_token
AUTH_REFRESH_COOKIE_NAME=qa_refresh_token
AUTH_COOKIE_SAME_SITE=lax
